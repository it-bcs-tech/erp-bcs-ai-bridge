# ==========================================
# AI Bridge Configuration
# ==========================================

# ── LLM Provider (OpenAI-compatible API) ──
# Bisa menggunakan Groq, OpenRouter, Together AI, atau provider lain
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_API_KEY=your-api-key-here
LLM_MODEL=qwen/qwen3-32b

# ── PostgreSQL Database (Direct Connection) ─────────────────────
DATABASE_URL=postgresql+asyncpg://bcs_admin:password@localhost:5433/mybcs_db

# ── Service Configuration ───────────────────────────────────────
AI_BRIDGE_HOST=0.0.0.0
AI_BRIDGE_PORT=8000
AI_BRIDGE_DEBUG=false
